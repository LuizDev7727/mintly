{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts",
    "build": "tsdown",
    "db:generate": "dotenv -e .env drizzle-kit generate",
    "db:migrate": "dotenv -e .env drizzle-kit migrate",
    "db:ui": "dotenv -e .env drizzle-kit studio",
    "db:seed": "dotenv -e .env tsx src/infra/db/seed.ts",
    "test": "dotenv -e .env vitest run",
    "test:ui": "dotenv -e .env vitest --ui",
    "trigger:dev": "pnpm dlx trigger.dev@latest dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-storage": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/otel": "^0.18.1",
    "@google/genai": "^2.11.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-pg": "^0.70.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@trigger.dev/sdk": "4.5.4",
    "better-auth": "^1.6.13",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "googleapis": "^173.0.0",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "replicate": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
