    "@faker-js/faker": "^10.4.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.58.0",
    "@trigger.dev/build": "4.5.4",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.9",
    "dotenv-cli": "^11.0.0",
    "supertest": "^7.2.2",
